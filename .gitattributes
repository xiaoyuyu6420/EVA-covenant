# Auto detect text files and normalize line endings
* text=auto

# Force specific line endings for common files
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.css text eol=lf
*.prisma text eol=lf

# Shell scripts must use LF
*.sh text eol=lf

# Windows batch files use CRLF
*.bat text eol=crlf

# Binary files
*.db binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
